# LLM Provider: mock | openai | glm
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# GLM (OpenAI-compatible)
GLM_API_KEY=
GLM_MODEL=glm-4-plus
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Brave Search API (for web_search tool)
BRAVE_API_KEY=

# SearXNG (local search engine fallback when Brave is not configured)
SEARXNG_URL=http://127.0.0.1:8080
